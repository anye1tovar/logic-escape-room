PORT=4000
# Local example. In production, use the Neon connection string from Koyeb env vars.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/logic_escape_room
# Use true for Neon production connections.
DATABASE_SSL=false

# Auth
# Generate a strong value for every non-local environment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-strong-random-secret
AUTH_TOKEN_TTL_SECONDS=28800

# Comma-separated allowed origins for CORS (e.g. https://your-site.vercel.app,https://your-domain.com)
CORS_ORIGINS=
