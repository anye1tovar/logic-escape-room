PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/logic_escape_room
DATABASE_SSL=false

# Auth
# Generate a strong value for every non-local environment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-strong-random-secret
AUTH_TOKEN_TTL_SECONDS=28800

# Comma-separated allowed origins for CORS (e.g. https://your-site.vercel.app)
CORS_ORIGINS=
